{
  "cosmos-installer": {
    "form": [
      {
        "name": "adminPin",
        "label": "Admin PIN (used to open settings – change from the default 1234)",
        "initialValue": "1234",
        "type": "text"
      }
    ]
  },
  "minVersion": "0.7.6",
  "services": {
    "{ServiceName}": {
      "image": "ghcr.io/t1dude/kidstaskmgr:latest",
      "container_name": "{ServiceName}",
      "restart": "unless-stopped",
      "environment": [
        "NODE_ENV=production",
        "DB_PATH=/app/data/tasks.db",
        "PORT=3001",
        "ADMIN_PIN={Context.adminPin}"
      ],
      "labels": {
        "cosmos-force-network-secured": "true",
        "cosmos-auto-update": "true"
      },
      "volumes": [
        {
          "source": "{ServiceName}-data",
          "target": "/app/data",
          "type": "volume"
        }
      ],
      "routes": [
        {
          "name": "{ServiceName}",
          "description": "Family weekly planner – tasks, calendar, and dinner plan",
          "useHost": true,
          "target": "http://{ServiceName}:3001",
          "mode": "SERVAPP",
          "Timeout": 14400000,
          "ThrottlePerMinute": 6000,
          "BlockCommonBots": true,
          "SmartShield": {
            "Enabled": true
          }
        }
      ]
    }
  }
}
